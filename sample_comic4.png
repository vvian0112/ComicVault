package com.example.comicvault

import android.content.Intent
import android.os.Bundle
import android.widget.Button
import android.widget.ImageView
import android.widget.TextView
import androidx.appcompat.app.AppCompatActivity
import com.google.android.material.appbar.MaterialToolbar
import androidx.core.content.ContextCompat


class DetailActivity : AppCompatActivity() {

    override fun onCreate(savedInstanceState: Bundle?) {
        super.onCreate(savedInstanceState)
        setContentView(R.layout.activity_detail)

        // Toolbar setup
        val toolbar = findViewById<MaterialToolbar>(R.id.topAppBarDetail)

        toolbar.setBackgroundColor(ContextCompat.getColor(this, R.color.md_theme_primary))
        toolbar.setTitleTextColor(ContextCompat.getColor(this, R.color.md_theme_onPrimary))
        toolbar.navigationIcon?.setTint(ContextCompat.getColor(this, R.color.md_theme_onPrimary))
        toolbar.overflowIcon?.setTint(ContextCompat.getColor(this, R.color.md_theme_onPrimary))


        // Back button
        toolbar.setNavigationOnClickListener {
            onBackPressedDispatcher.onBackPressed()
        }

        // Retrieve intent data
        val title = intent.getStringExtra("title") ?: "No Title"
        val desc = intent.getStringExtra("desc") ?: "No Description"
        val cost = intent.getStringExtra("cost") ?: "Unknown Price"
        val imageRes = intent.getIntExtra("image", 0)

        // Bind views
        val img = findViewById<ImageView>(R.id.detailImage)
        val tvTitle = findViewById<TextView>(R.id.detailTitle)
        val tvDesc = findViewById<TextView>(R.id.detailDesc)
        val tvCost = findViewById<TextView>(R.id.detailCost)

        // Set values
        img.setImageResource(imageRes)
        tvTitle.text = title
        tvDesc.text = desc
        tvCost.text = getString(R.string.comic_cost, cost)

        // Apply Large Text toggle (runtime-only)
        if (AppState.largeTextEnabled) {
            tvTitle.textSize = 30f
            tvDesc.textSize = 20f
            tvCost.textSize = 20f
        } else {
            tvTitle.textSize = 22f
            tvDesc.textSize = 15f
            tvCost.textSize = 16f
        }


        img.contentDescription = getString(R.string.cover_desc, title)

// TRY BUTTON
        findViewById<Button>(R.id.btnTry).setOnClickListener {

            val dialogView = layoutInflater.inflate(R.layout.dialog_preview, null)
            val previewImage = dialogView.findViewById<ImageView>(R.id.previewImage)

            // Set preview image based on title
            when (title) {

                "Lawak Kampus (Untuk korang yang tengah bosan!)" ->
                    previewImage.setImageResource(R.drawable.sample_comic1)

                "Buku Aktiviti – Edisi Ulang Tahun" ->
                    previewImage.setImageResource(R.drawable.sample_comic2)

                "Lawak Kampus Character Card Edition" ->
                    previewImage.setImageResource(R.drawable.sample_comic3)

                "Lawak Kampus Jilid 17" ->
                    previewImage.setImageResource(R.drawable.sample_comic4)

                "Lawak Kampus Jilid 25" ->
                    previewImage.setImageResource(R.drawable.sample_comic5)

                "Lawak Kampus Jilid 26" ->
                    previewImage.setImageResource(R.drawable.sample_comic6)

                "Lawak Kampus Jilid 28" ->
                    previewImage.setImageResource(R.drawable.sample_comic7)

                "Lawak Kampus Jilid 35" ->
                    previewImage.setImageResource(R.drawable.sample_comic8)

                "Lawak Kampus Jilid 41" ->
                    previewImage.setImageResource(R.drawable.sample_comic9)

                else ->
                    previewImage.setImageResource(R.drawable.sample_comic1)
            }

            // Accessibility for TalkBack
            previewImage.contentDescription = getString(R.string.preview_desc, title)

            val builder = androidx.appcompat.app.AlertDialog.Builder(this)
            builder.setView(dialogView)
            builder.setCancelable(true)

            val dialog = builder.create()
            dialog.show()
        }


        // Share button
        findViewById<Button>(R.id.btnShare).setOnClickListener {
            val shareIntent = Intent(Intent.ACTION_SEND).apply {
                type = "text/plain"
                putExtra(
                    Intent.EXTRA_TEXT,
                    "Check out this comic!\n\nTitle: $title\nPrice: $cost\n\nDescription:\n$desc"
                )
            }
            startActivity(Intent.createChooser(shareIntent, "Share via"))
        }
    }
}
